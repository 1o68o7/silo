# Worker léger sans Scrapling (SILO_USE_STEALTHY_FETCHER=false)
# Pour dev/CI ou sites simples sans anti-bot
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
# Exclure scrapling pour build léger
RUN grep -v "scrapling" requirements.txt > /tmp/req.txt && \
    pip install --no-cache-dir -r /tmp/req.txt

RUN python -m spacy download fr_core_news_lg 2>/dev/null || true

COPY . .
ENV PYTHONPATH=/app
ENV SILO_USE_STEALTHY_FETCHER=false
CMD ["python", "-m", "worker.run"]
